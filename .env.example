APP_ENV=dev
LOG_LEVEL=INFO

DATA_DIR=data
RAW_DATA_DIR=data/raw
VECTOR_DB_DIR=data/chroma

COLLECTION_NAME=rag_documents
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# MMR (Maximal Marginal Relevance) settings for retrieval diversity
USE_MMR=true
MMR_FETCH_K=20
MMR_LAMBDA_MULT=0.5

# Chat history settings
USE_HISTORY=true

USE_LLM=true

LLM_PROVIDER=openai
